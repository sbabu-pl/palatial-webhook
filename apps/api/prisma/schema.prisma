generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  API
  MANUAL
}

enum LeadStatus {
  NEW
  CAPTURE_IN_PROGRESS
  QUALIFIED
  HUMAN_HANDOFF_PENDING
  HUMAN_ASSIGNED
  CONTACTED
  FOLLOW_UP_REQUESTED
  CLOSED_WON
  CLOSED_LOST
  ARCHIVED
}

enum LeadPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ProductType {
  MOTOR
  LIFE
  MEDICAL
  POLICY_FOLLOW_UP
  OTHER
}

enum SessionState {
  ROOT_MENU
  AWAITING_MOTOR_DETAILS
  AWAITING_LIFE_DETAILS
  AWAITING_MEDICAL_DETAILS
  AWAITING_POLICY_DETAILS
}

enum SessionStatus {
  ACTIVE
  HANDED_OFF
  CLOSED
}

enum AgentStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum AssignmentStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum LeadEventType {
  CREATED
  UPDATED
  NOTE_ADDED
  WEBSITE_CAPTURE
  WHATSAPP_INBOUND
  WHATSAPP_OUTBOUND
  HANDOFF_REQUESTED
  HANDOFF_ASSIGNED
  HANDOFF_UNASSIGNED
  STATUS_CHANGED
}

enum ActorType {
  SYSTEM
  CUSTOMER
  AGENT
  API
}

model Lead {
  id             String       @id @default(cuid())
  source         LeadSource   @default(WHATSAPP)
  status         LeadStatus   @default(NEW)
  priority       LeadPriority @default(NORMAL)
  productType    ProductType?
  fullName       String?
  email          String?
  phoneE164      String?      @unique
  waId           String?      @unique
  notes          String?
  sourcePage     String?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  metadata       Json?
  currentAgentId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  currentAgent Agent?            @relation("CurrentAgent", fields: [currentAgentId], references: [id], onDelete: SetNull)
  sessions     ChatSession[]
  assignments  LeadAssignment[]
  events       LeadEvent[]

  @@index([status, productType])
  @@index([currentAgentId])
  @@index([source])
}

model ChatSession {
  id             String        @id @default(cuid())
  waId           String        @unique
  name           String?
  state          SessionState  @default(ROOT_MENU)
  status         SessionStatus @default(ACTIVE)
  lastIntent     String?
  leadId         String?
  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
}

model Agent {
  id              String      @id @default(cuid())
  name            String
  email           String      @unique
  phoneE164       String?
  status          AgentStatus @default(AVAILABLE)
  capacity        Int         @default(20)
  acceptsWhatsapp Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  currentLeads Lead[]           @relation("CurrentAgent")
  assignments  LeadAssignment[]
}

model LeadAssignment {
  id         String           @id @default(cuid())
  leadId     String
  agentId    String
  status     AssignmentStatus @default(OPEN)
  reason     String?
  metadata   Json?
  assignedAt DateTime         @default(now())
  closedAt   DateTime?

  lead  Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agent Agent @relation(fields: [agentId], references: [id], onDelete: Restrict)

  @@index([leadId, status])
  @@index([agentId, status])
}

model LeadEvent {
  id        String        @id @default(cuid())
  leadId    String
  type      LeadEventType
  actorType ActorType     @default(SYSTEM)
  actorId   String?
  message   String?
  metadata  Json?
  createdAt DateTime      @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([type])
}

model ProcessedMessage {
  id           String   @id
  waId         String
  type         String
  status       String   @default("RECEIVED")
  payloadJson  Json?
  errorMessage String?
  receivedAt   DateTime @default(now())
  processedAt  DateTime?

  @@index([waId])
}